# ── EstacionAR · variables de entorno (ejemplo) ─────────────────────────────
# Copiar a .env y completar con credenciales REALES. Nunca commitear .env.

# API
API_PORT=4000
NODE_ENV=development

# Secreto para firmar tokens QR de permisionarios (HMAC). Generar uno fuerte.
QR_SIGNING_SECRET=cambiar-por-secreto-fuerte-de-32-bytes-minimo

# Supabase (cuando se conecte la BD real — la demo corre sin esto)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Mercado Pago (cuando se active el pago real — la demo simula la aprobacion)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# Frontends (Vite) — URL de la API
VITE_API_URL=http://localhost:4000
